# Supabase credentials — copy to .env (which is git-ignored) and fill in.
# Find these in your Supabase project: Settings → API.
# The anon key is safe to expose in the client; data is protected by Row-Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
